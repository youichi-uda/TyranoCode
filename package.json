{
  "name": "tyranocode",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "version": "0.1.0",
  "publisher": "tyranocode",
  "repository": {
    "type": "git",
    "url": "https://github.com/youichi-uda/TyranoCode.git"
  },
  "license": "SEE LICENSE IN LICENSE.md",
  "l10n": "./l10n",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Debuggers",
    "Linters",
    "Visualization",
    "Testing"
  ],
  "keywords": [
    "tyranoscript",
    "tyranobuilder",
    "visual novel",
    "ティラノスクリプト",
    "ティラノビルダー"
  ],
  "activationEvents": [
    "workspaceContains:**/*.ks",
    "workspaceContains:tyrano/tyrano.js"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "tyranoscript",
        "aliases": [
          "TyranoScript",
          "ティラノスクリプト"
        ],
        "extensions": [
          ".ks"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "tyranoscript",
        "scopeName": "source.tyranoscript",
        "path": "./syntaxes/tyranoscript.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "tyranoscript",
        "path": "./snippets/tyranoscript.json"
      }
    ],
    "configurationDefaults": {
      "[tyranoscript]": {
        "editor.quickSuggestions": {
          "other": "on",
          "comments": "off",
          "strings": "on"
        }
      }
    },
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "tyranodev.projectRoot": {
          "type": "string",
          "default": "",
          "description": "%config.projectRoot.description%"
        },
        "tyranodev.diagnostics.enable": {
          "type": "boolean",
          "default": true,
          "description": "%config.diagnostics.enable%"
        },
        "tyranodev.diagnostics.undefinedLabel": {
          "type": "boolean",
          "default": true,
          "description": "%config.diagnostics.undefinedLabel%"
        },
        "tyranodev.diagnostics.undefinedMacro": {
          "type": "boolean",
          "default": true,
          "description": "%config.diagnostics.undefinedMacro%"
        },
        "tyranodev.diagnostics.missingResource": {
          "type": "boolean",
          "default": true,
          "description": "%config.diagnostics.missingResource%"
        },
        "tyranodev.diagnostics.unusedLabel": {
          "type": "boolean",
          "default": true,
          "description": "%config.diagnostics.unusedLabel%"
        },
        "tyranodev.diagnostics.unreachableCode": {
          "type": "boolean",
          "default": true,
          "description": "%config.diagnostics.unreachableCode%"
        },
        "tyranodev.devMode": {
          "type": "boolean",
          "default": false,
          "description": "Developer mode: bypass license check and unlock all Pro features."
        },
        "tyranodev.license.key": {
          "type": "string",
          "default": "",
          "description": "%config.license.key.description%",
          "markdownDescription": "%config.license.key.markdownDescription%"
        }
      }
    },
    "commands": [
      {
        "command": "tyranodev.showFlowGraph",
        "title": "%command.showFlowGraph%",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "tyranodev.analyzeProject",
        "title": "%command.analyzeProject%"
      },
      {
        "command": "tyranodev.runAllRoutes",
        "title": "%command.runAllRoutes%"
      },
      {
        "command": "tyranodev.profileScene",
        "title": "%command.profileScene%"
      },
      {
        "command": "tyranodev.renameSymbol",
        "title": "%command.renameSymbol%"
      },
      {
        "command": "tyranodev.goToDefinition",
        "title": "%command.goToDefinition%"
      },
      {
        "command": "tyranodev.findAllReferences",
        "title": "%command.findAllReferences%"
      },
      {
        "command": "tyranodev.activateLicense",
        "title": "%command.activateLicense%"
      },
      {
        "command": "tyranodev.showVariables",
        "title": "%command.showVariables%"
      },
      {
        "command": "tyranodev.refreshVariables",
        "title": "%command.refreshVariables%"
      },
      {
        "command": "tyranodev.previewScene",
        "title": "%command.previewScene%",
        "icon": "$(open-preview)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "tyranodev.showFlowGraph",
          "when": "resourceLangId == tyranoscript",
          "group": "navigation"
        },
        {
          "command": "tyranodev.previewScene",
          "when": "resourceLangId == tyranoscript",
          "group": "navigation"
        }
      ]
    },
    "breakpoints": [
      {
        "language": "tyranoscript"
      }
    ],
    "debuggers": [
      {
        "type": "tyranoscript",
        "label": "%debugger.label%",
        "languages": [
          "tyranoscript"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [
              "projectRoot"
            ],
            "properties": {
              "projectRoot": {
                "type": "string",
                "description": "%debugger.projectRoot.description%",
                "default": "${workspaceFolder}"
              },
              "scene": {
                "type": "string",
                "description": "%debugger.scene.description%",
                "default": "first.ks"
              },
              "port": {
                "type": "number",
                "description": "%debugger.port.description%",
                "default": 9871
              }
            }
          }
        },
        "configurationSnippets": [
          {
            "label": "%debugger.snippet.label%",
            "description": "%debugger.snippet.description%",
            "body": {
              "type": "tyranoscript",
              "request": "launch",
              "name": "Debug TyranoScript",
              "projectRoot": "^\"\\${workspaceFolder}\"",
              "scene": "first.ks",
              "port": 9871
            }
          }
        ]
      }
    ],
    "views": {
      "debug": [
        {
          "id": "tyranodev.variableWatch",
          "name": "%view.variableWatch%",
          "when": "debugType == 'tyranoscript'"
        },
        {
          "id": "tyranodev.tagTracker",
          "name": "%view.tagTracker%",
          "when": "debugType == 'tyranoscript'"
        }
      ],
      "explorer": [
        {
          "id": "tyranodev.variablesView",
          "name": "TyranoScript Variables",
          "when": "tyranodev.projectDetected"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest"
  },
  "devDependencies": {
    "@types/dagre": "^0.7.54",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vscode/debugadapter": "^1.65.0",
    "@vscode/debugprotocol": "^1.65.0",
    "@vscode/l10n-dev": "^0.0.35",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@vscode/debugadapter": "^1.65.0",
    "dagre": "^0.8.5",
    "mermaid": "^11.13.0",
    "ws": "^8.19.0"
  }
}
